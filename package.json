{
  "name": "flywheel-visual-pipeline",
  "version": "0.1.0",
  "description": "Takes a finished LinkedIn-style post + brand design context and produces polished, on-brand visuals as HTML/CSS, exported to PDF and PNG.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "pipeline": "tsx src/cli.ts --run",
    "demo": "tsx src/demo.ts",
    "stage1": "tsx src/stages/stage1-design-system/index.ts",
    "audit-tokens": "tsx src/stages/stage1-design-system/audit-tokens-vision.ts",
    "stage2": "tsx src/stages/stage2-post-to-concept/index.ts",
    "stage3": "tsx src/stages/stage3-concept-to-html/index.ts",
    "workstream-b": "tsx src/workstream-b/index.ts",
    "workstream-b:refine": "tsx src/workstream-b/refinement-split-quote-card.ts && tsx src/workstream-b/validation-inter-rater.ts && tsx src/workstream-b/validation-held-out.ts && tsx src/workstream-b/analysis-engagement.ts",
    "harness": "tsx src/server.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "cheerio": "^1.0.0",
    "dotenv": "^17.4.2",
    "handlebars": "^4.7.8",
    "langfuse": "^3.29.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.52.0",
    "zod": "^3.24.0",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
