<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 1200px;
      height: 630px;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #f0efe9;
      color: #111111;
      overflow: hidden;
    }

    .container {
      width: 1200px;
      height: 630px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 56px 80px;
      position: relative;
    }

    .card {
      background: #ffffff;
      border-radius: 8px;
      padding: 48px 56px;
      max-width: 880px;
      width: 100%;
      border-left: 5px solid #e6ff00;
      box-shadow: 0 2px 24px rgba(0, 0, 0, 0.04), 0 0 0 1px rgba(0, 0, 0, 0.03);
    }

    .badge {
      display: inline-block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #111111;
      background: #e6ff00;
      padding: 5px 14px;
      border-radius: 4px;
      margin-bottom: 24px;
    }

    .headline {
      font-size: 40px;
      font-weight: 700;
      line-height: 1.15;
      letter-spacing: -0.03em;
      color: #111111;
      margin-bottom: 16px;
    }

    .subtext {
      font-size: 19px;
      font-weight: 400;
      line-height: 1.55;
      color: #555555;
    }

    .logo {
      position: absolute;
      bottom: 32px;
      right: 48px;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: #aaaaaa;
      text-transform: uppercase;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <div class="badge">Key Takeaway</div>
      <h1 class="headline">{{headline}}</h1>
      {{#if subtext}}
      <p class="subtext">{{subtext}}</p>
      {{/if}}
    </div>
    <div class="logo">Flywheel</div>
  </div>
</body>
</html>
