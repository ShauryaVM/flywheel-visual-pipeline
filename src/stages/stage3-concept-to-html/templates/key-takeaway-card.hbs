<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 1200px;
      height: 630px;
      font-family: {{{ds.fontFamily}}};
      background: {{ds.surface}};
      color: {{ds.textPrimary}};
      overflow: hidden;
    }

    .canvas {
      width: 1200px;
      height: 630px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    .dot-field {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none;
      overflow: hidden;
    }
    .dot-field circle { fill: #000000; }

    .warm-bar {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 3px;
      background: linear-gradient(90deg, {{ds.accent}} 0%, transparent 60%);
    }

    .card {
      background: {{ds.background}};
      border: 1px solid rgba(215, 200, 175, 0.5);
      box-shadow: rgba(215, 200, 175, 0.25) 0px 4px 20px 0px, rgba(0, 0, 0, 0.06) 0px 1px 4px 0px, rgba(255, 252, 248, 0.5) 0px 1px 1px 0px inset, rgba(215, 200, 175, 0.15) 0px -1px 1px 0px inset;
      padding: 56px 72px;
      max-width: 880px;
      width: 100%;
      position: relative;
      z-index: 1;
    }

    .card-accent {
      position: absolute;
      top: 0;
      left: 0;
      width: 3px;
      height: 100%;
      background: {{ds.accent}};
    }

    .badge {
      display: inline-block;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: {{ds.background}};
      background: {{ds.primary}};
      padding: 5px 14px;
      margin-bottom: 24px;
    }

    .headline {
      font-size: 36px;
      font-weight: 600;
      line-height: 1.15;
      letter-spacing: -0.03em;
      color: {{ds.primary}};
      margin-bottom: 20px;
    }

    .subtext {
      font-size: 18px;
      font-weight: 400;
      line-height: 1.55;
      color: {{ds.textSubtle}};
    }

    .footer {
      position: absolute;
      bottom: 28px;
      left: 0;
      right: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 56px;
      z-index: 1;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .brand svg { width: 16px; height: 16px; }

    .brand-name {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: {{ds.textDisabled}};
      text-transform: uppercase;
    }

    .url {
      font-family: {{{ds.monoFamily}}};
      font-size: 11px;
      color: {{ds.textFaint}};
    }
  </style>
</head>
<body>
