<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 1200px;
      height: 630px;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #111111;
      color: #ffffff;
      overflow: hidden;
    }

    .container {
      width: 1200px;
      height: 630px;
      display: flex;
      padding: 44px 64px;
      gap: 48px;
      position: relative;
    }

    .left-panel {
      flex: 0 0 360px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .accent-dot {
      width: 10px;
      height: 10px;
      background: #e6ff00;
      border-radius: 50%;
      margin-bottom: 20px;
    }

    .headline {
      font-size: 36px;
      font-weight: 700;
      line-height: 1.12;
      letter-spacing: -0.03em;
      color: #ffffff;
    }

    {{#if subtext}}
    .subtext {
      font-size: 15px;
      font-weight: 400;
      line-height: 1.5;
      color: rgba(255, 255, 255, 0.5);
      margin-top: 14px;
    }
    {{/if}}

    .right-panel {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 6px;
    }

    .feature-row {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 14px 20px;
      border-radius: 6px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .feature-icon {
      flex: 0 0 28px;
      height: 28px;
      background: rgba(230, 255, 0, 0.12);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #e6ff00;
      font-size: 14px;
    }

    .feature-text {
      font-size: 16px;
      font-weight: 500;
      line-height: 1.4;
      color: rgba(255, 255, 255, 0.85);
      flex: 1;
    }

    .logo {
      position: absolute;
      bottom: 28px;
      right: 48px;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: rgba(255, 255, 255, 0.2);
      text-transform: uppercase;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="left-panel">
      <div class="accent-dot"></div>
      <h1 class="headline">{{headline}}</h1>
      {{#if subtext}}
      <p class="subtext">{{subtext}}</p>
      {{/if}}
    </div>
    <div class="right-panel">
      {{#each data_points}}
      <div class="feature-row">
        <div class="feature-icon">&#10003;</div>
        <div class="feature-text">{{this}}</div>
      </div>
      {{/each}}
    </div>
    <div class="logo">Flywheel</div>
  </div>
</body>
</html>
