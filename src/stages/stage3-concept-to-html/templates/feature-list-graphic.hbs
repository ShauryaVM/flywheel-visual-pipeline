        <circle cx="1160" cy="350" r="3" fill="#000000" opacity="0.18"/>
        <circle cx="730" cy="360" r="5" fill="#000000" opacity="0.1"/>
        <circle cx="1120" cy="390" r="7" fill="#000000" opacity="0.08"/>
        <circle cx="1060" cy="420" r="4" fill="#000000" opacity="0.14"/>
        <circle cx="700" cy="430" r="3" fill="#000000" opacity="0.16"/>
        <circle cx="1150" cy="450" r="10" fill="#000000" opacity="0.07"/>
