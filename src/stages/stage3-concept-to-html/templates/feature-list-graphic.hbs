        <line x1="810" y1="120" x2="900" y2="95" stroke="#000000" stroke-width="0.5" opacity="0.04"/>
        <line x1="980" y1="115" x2="1060" y2="100" stroke="#000000" stroke-width="0.5" opacity="0.06"/>
        <line x1="1100" y1="320" x2="1160" y2="350" stroke="#000000" stroke-width="0.5" opacity="0.05"/>
        <line x1="1120" y1="390" x2="1060" y2="420" stroke="#000000" stroke-width="0.5" opacity="0.05"/>
