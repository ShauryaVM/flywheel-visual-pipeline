<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 1200px;
      height: 630px;
      font-family: {{{ds.fontFamily}}};
      background: {{ds.surface}};
      color: {{ds.textPrimary}};
      overflow: hidden;
    }

    .canvas {
      width: 1200px;
      height: 630px;
      display: flex;
      position: relative;
    }

    .warm-bar {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 3px;
      background: linear-gradient(90deg, {{ds.accent}} 0%, transparent 50%);
    }

    .left {
      flex: 0 0 380px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 52px 40px 52px 64px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: {{ds.background}};
      background: {{ds.primary}};
      padding: 5px 14px;
      margin-bottom: 24px;
      align-self: flex-start;
    }

    .headline {
      font-size: 32px;
      font-weight: 600;
      line-height: 1.12;
      letter-spacing: -0.03em;
      color: {{ds.primary}};
    }

    .subtext {
      font-size: 15px;
      font-weight: 400;
      line-height: 1.55;
      color: {{ds.textMuted}};
      margin-top: 14px;
    }

    .brand-area {
      margin-top: auto;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .brand-area svg { width: 16px; height: 16px; }

    .brand-name {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: {{ds.textDisabled}};
      text-transform: uppercase;
    }

    .right {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 40px 56px 40px 0;
      gap: 0;
    }

    .card {
      background: {{ds.background}};
      border: 1px solid rgba(215, 200, 175, 0.5);
      box-shadow: rgba(215, 200, 175, 0.25) 0px 4px 20px 0px, rgba(0, 0, 0, 0.06) 0px 1px 4px 0px, rgba(255, 252, 248, 0.5) 0px 1px 1px 0px inset, rgba(215, 200, 175, 0.15) 0px -1px 1px 0px inset;
      padding: 20px 48px;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .feature-row {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 11px 0;
      border-bottom: 1px solid rgba(215, 200, 175, 0.2);
    }

    .feature-row:last-child {
      border-bottom: none;
    }

    .feature-icon {
      flex: 0 0 8px;
      height: 8px;
      background: {{ds.primary}};
      border-radius: 50%;
    }

    .feature-text {
      font-size: 14.5px;
      font-weight: 500;
      line-height: 1.4;
      color: {{ds.textSecondary}};
      flex: 1;
    }

    .url {
      position: absolute;
      bottom: 24px;
      right: 48px;
      font-family: {{{ds.monoFamily}}};
      font-size: 11px;
      color: {{ds.textFaint}};
    }

    .dot-field {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none;
      z-index: 0;
    }

    .gradient-footer {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 60px;
      background: linear-gradient(180deg, transparent 0%, rgba(215, 200, 175, 0.06) 100%);
      pointer-events: none;
    }
  </style>
</head>
<body>
