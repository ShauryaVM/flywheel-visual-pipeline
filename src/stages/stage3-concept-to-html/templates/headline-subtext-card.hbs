<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 1200px;
      height: 630px;
      font-family: {{{ds.fontFamily}}};
      background: {{ds.background}};
      color: {{ds.textPrimary}};
      overflow: hidden;
    }

    .canvas {
      width: 1200px;
      height: 630px;
      display: grid;
      grid-template-columns: 1fr;
      grid-template-rows: 3px 1fr auto;
      position: relative;
    }

    .dot-field {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none;
      z-index: 0;
    }

    .warm-bar {
      background: linear-gradient(90deg, {{ds.accent}} 0%, transparent 40%);
      z-index: 1;
    }

    .content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 0 80px;
      z-index: 1;
    }

    .eyebrow {
      font-family: {{{ds.monoFamily}}};
      font-size: 12px;
      font-weight: 400;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: {{ds.textMuted}};
      margin-bottom: 20px;
    }

    .headline {
      font-size: 52px;
      font-weight: 600;
      line-height: 1.05;
      letter-spacing: -0.035em;
      color: {{ds.primary}};
      max-width: 880px;
      margin-bottom: 24px;
    }

    .divider {
      width: 48px;
      height: 2px;
      background: {{ds.accent}};
      margin-bottom: 24px;
    }

    .subtext {
      font-size: 20px;
      font-weight: 400;
      line-height: 1.55;
      color: {{ds.textSubtle}};
      max-width: 680px;
    }

    .footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 80px 36px;
      z-index: 1;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .brand svg { width: 18px; height: 18px; }

    .brand-name {
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: {{ds.textDisabled}};
      text-transform: uppercase;
    }

    .url {
      font-family: {{{ds.monoFamily}}};
      font-size: 12px;
      color: {{ds.textFaint}};
    }

    .gradient-footer {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 100px;
      background: linear-gradient(to bottom, transparent, rgba(250,249,246,1));
      pointer-events: none;
      z-index: 0;
    }

    .flywheel-watermark {
      position: absolute;
      bottom: 80px;
      left: 0;
      width: 100%;
      text-align: center;
      font-size: 160px;
      font-weight: 700;
      letter-spacing: 0.05em;
      color: rgba(0, 0, 0, 0.03);
      text-transform: uppercase;
      pointer-events: none;
      line-height: 1;
      z-index: 0;
    }
  </style>
</head>
