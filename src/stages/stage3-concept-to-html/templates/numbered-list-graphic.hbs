<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 1200px;
      height: 630px;
      font-family: {{{ds.fontFamily}}};
      background: {{ds.background}};
      color: {{ds.textPrimary}};
      overflow: hidden;
    }

    .canvas {
      width: 1200px;
      height: 630px;
      display: flex;
      position: relative;
    }

    .warm-bar {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 3px;
      background: linear-gradient(90deg, {{ds.accent}} 0%, transparent 45%);
    }

    .left {
      flex: 0 0 340px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 52px 48px 52px 64px;
      border-right: 1px solid rgba(215, 200, 175, 0.3);
    }

    .accent-mark {
      width: 32px;
      height: 2px;
      background: {{ds.accent}};
      margin-bottom: 24px;
    }

    .headline {
      font-size: 30px;
      font-weight: 600;
      line-height: 1.12;
      letter-spacing: -0.03em;
      color: {{ds.primary}};
    }

    .subtext {
      font-size: 14px;
      font-weight: 400;
      line-height: 1.55;
      color: {{ds.textMuted}};
      margin-top: 14px;
    }

    .brand-left {
      margin-top: auto;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .brand-left svg { width: 16px; height: 16px; }

    .brand-name {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: {{ds.textDisabled}};
      text-transform: uppercase;
    }

    .right {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 36px 56px 36px 40px;
      gap: 2px;
      overflow: hidden;
    }

    .list-item {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 10px 16px;
      border-bottom: 1px solid rgba(215, 200, 175, 0.2);
    }

    .list-item:last-child {
      border-bottom: none;
    }

    .item-num {
      flex: 0 0 30px;
      height: 30px;
      background: {{ds.primary}};
      color: {{ds.background}};
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: {{{ds.monoFamily}}};
      font-size: 13px;
      font-weight: 500;
      border-radius: 0;
    }

    .item-text {
      font-size: 14.5px;
      font-weight: 500;
      line-height: 1.4;
      color: {{ds.textSecondary}};
      flex: 1;
    }

    .url {
      position: absolute;
      bottom: 24px;
      right: 48px;
      font-family: {{{ds.monoFamily}}};
      font-size: 11px;
      color: {{ds.textFaint}};
    }

    .dot-field {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none;
      z-index: 0;
    }

    .warm-border {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 1px;
      background: rgba(215, 200, 175, 0.4);
    }
  </style>
</head>
<body>
  <div class="canvas">
    <div class="dot-field">
      <svg width="1200" height="630" xmlns="http://www.w3.org/2000/svg">
        <circle cx="680" cy="30" r="6" fill="#000000" opacity="0.1"/>
        <circle cx="750" cy="55" r="10" fill="#000000" opacity="0.07"/>
        <circle cx="830" cy="35" r="4" fill="#000000" opacity="0.15"/>
        <circle cx="900" cy="60" r="8" fill="#000000" opacity="0.08"/>
        <circle cx="970" cy="38" r="3" fill="#000000" opacity="0.2"/>
        <circle cx="1040" cy="62" r="14" fill="#000000" opacity="0.06"/>
        <circle cx="1110" cy="40" r="5" fill="#000000" opacity="0.12"/>
        <circle cx="1160" cy="72" r="3" fill="#000000" opacity="0.18"/>
        <circle cx="710" cy="100" r="4" fill="#000000" opacity="0.12"/>
        <circle cx="790" cy="120" r="7" fill="#000000" opacity="0.08"/>
        <circle cx="870" cy="95" r="3" fill="#000000" opacity="0.16"/>
        <circle cx="950" cy="110" r="5" fill="#000000" opacity="0.1"/>
        <circle cx="1030" cy="130" r="12" fill="#000000" opacity="0.06"/>
        <circle cx="1100" cy="105" r="4" fill="#000000" opacity="0.14"/>
        <circle cx="1160" cy="140" r="3" fill="#000000" opacity="0.2"/>
        <circle cx="700" cy="190" r="5" fill="#000000" opacity="0.1"/>
        <circle cx="1150" cy="200" r="6" fill="#000000" opacity="0.08"/>
        <circle cx="1080" cy="230" r="3" fill="#000000" opacity="0.16"/>
        <circle cx="720" cy="270" r="8" fill="#000000" opacity="0.07"/>
        <circle cx="1140" cy="280" r="4" fill="#000000" opacity="0.12"/>
        <circle cx="1100" cy="330" r="15" fill="#000000" opacity="0.06"/>
        <circle cx="1160" cy="350" r="3" fill="#000000" opacity="0.18"/>
        <circle cx="700" cy="370" r="4" fill="#000000" opacity="0.12"/>
        <circle cx="1130" cy="400" r="7" fill="#000000" opacity="0.08"/>
        <circle cx="1060" cy="430" r="3" fill="#000000" opacity="0.16"/>
        <circle cx="730" cy="440" r="6" fill="#000000" opacity="0.09"/>
        <circle cx="1150" cy="460" r="5" fill="#000000" opacity="0.1"/>
        <circle cx="1090" cy="490" r="10" fill="#000000" opacity="0.07"/>
        <circle cx="680" cy="510" r="3" fill="#000000" opacity="0.14"/>
        <circle cx="1140" cy="530" r="4" fill="#000000" opacity="0.12"/>
        <circle cx="1060" cy="560" r="6" fill="#000000" opacity="0.08"/>
        <circle cx="710" cy="570" r="3" fill="#000000" opacity="0.16"/>
        <circle cx="1160" cy="590" r="8" fill="#000000" opacity="0.07"/>
        <circle cx="950" cy="590" r="3" fill="#000000" opacity="0.12"/>
        <circle cx="100" cy="40" r="4" fill="#000000" opacity="0.1"/>
        <circle cx="170" cy="70" r="3" fill="#000000" opacity="0.14"/>
        <circle cx="60" cy="550" r="5" fill="#000000" opacity="0.08"/>
        <circle cx="140" cy="580" r="3" fill="#000000" opacity="0.12"/>
