<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 1200px;
      height: 630px;
      font-family: {{{ds.fontFamily}}};
      background: {{{ds.backgroundStyle}}};
      color: {{ds.textPrimary}};
      overflow: hidden;
    }

    .canvas {
      width: 1200px;
      height: 630px;
      display: flex;
      position: relative;
    }

    .warm-bar {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 3px;
      background: linear-gradient(90deg, {{ds.accent}} 0%, transparent 45%);
    }

    .left {
      flex: 0 0 340px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 52px 48px 52px 64px;
      border-right: 1px solid rgba({{ds.accentRgb}}, 0.3);
    }

    .accent-mark {
      width: 32px;
      height: 2px;
      background: {{ds.accent}};
      margin-bottom: 24px;
    }

    .headline {
      font-size: 30px;
      font-weight: 600;
      line-height: 1.12;
      letter-spacing: -0.03em;
      color: {{ds.primary}};
    }

    .subtext {
      font-size: 14px;
      font-weight: 400;
      line-height: 1.55;
      color: {{ds.textMuted}};
      margin-top: 14px;
    }

    .brand-left {
      margin-top: auto;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .brand-left svg { width: 16px; height: 16px; }

    .brand-name {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: {{ds.textDisabled}};
      text-transform: uppercase;
    }

    .right {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 36px 56px 36px 40px;
      gap: 2px;
      overflow: hidden;
    }

    .list-item {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 10px 16px;
      border-bottom: 1px solid rgba({{ds.accentRgb}}, 0.2);
    }

    .list-item:last-child {
      border-bottom: none;
    }

    .item-num {
      flex: 0 0 30px;
      height: 30px;
      background: {{ds.primary}};
      color: {{ds.background}};
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: {{{ds.monoFamily}}};
      font-size: 13px;
      font-weight: 500;
      border-radius: {{ds.radiusSm}};
    }

    .item-text {
      font-size: 14.5px;
      font-weight: 500;
      line-height: 1.4;
      color: {{ds.textSecondary}};
      flex: 1;
    }

    .url {
      position: absolute;
      bottom: 24px;
      right: 48px;
      font-family: {{{ds.monoFamily}}};
      font-size: 11px;
      color: {{ds.textFaint}};
    }

    .decorative-bg {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none;
      z-index: 0;
      opacity: 1.0;
    }

    .warm-border {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 1px;
      background: rgba({{ds.accentRgb}}, 0.4);
    }

    {{{ds.animationsCss}}}
  </style>
</head>
<body>
  <div class="canvas">
    <div class="decorative-bg">
      {{{ds.decorativePatternSvg}}}
    </div>
    {{{ds.animationHintsSvg}}}
    <div class="warm-bar"></div>
    <div class="left">
      <div class="accent-mark"></div>
      <h1 class="headline">{{headline}}</h1>
      {{#if subtext}}
      <p class="subtext">{{subtext}}</p>
      {{/if}}
      <div class="brand-left">
        {{#if ds.logoSvg}}{{{ds.logoSvg}}}{{/if}}
        <span class="brand-name">{{ds.brandName}}</span>
      </div>
    </div>
    <div class="right">
      {{#each data_points}}
      <div class="list-item">
        <div class="item-num">{{addOne @index}}</div>
        <div class="item-text">{{this}}</div>
      </div>
      {{/each}}
    </div>
    <span class="url">{{ds.brandUrl}}</span>
    <div class="warm-border"></div>
  </div>
</body>
</html>
