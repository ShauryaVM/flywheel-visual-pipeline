        <circle cx="850" cy="590" r="3" fill="#000000" opacity="0.1"/>
        <line x1="680" y1="30" x2="750" y2="55" stroke="#000000" stroke-width="0.5" opacity="0.06"/>
        <line x1="830" y1="35" x2="900" y2="60" stroke="#000000" stroke-width="0.5" opacity="0.05"/>
        <line x1="1040" y1="62" x2="1110" y2="40" stroke="#000000" stroke-width="0.5" opacity="0.05"/>
        <line x1="790" y1="120" x2="870" y2="95" stroke="#000000" stroke-width="0.5" opacity="0.04"/>
        <line x1="1030" y1="130" x2="1100" y2="105" stroke="#000000" stroke-width="0.5" opacity="0.06"/>
        <line x1="1100" y1="330" x2="1160" y2="350" stroke="#000000" stroke-width="0.5" opacity="0.05"/>
        <line x1="1130" y1="400" x2="1060" y2="430" stroke="#000000" stroke-width="0.5" opacity="0.05"/>
        <line x1="1090" y1="490" x2="1140" y2="530" stroke="#000000" stroke-width="0.5" opacity="0.04"/>
        <line x1="1060" y1="560" x2="1160" y2="590" stroke="#000000" stroke-width="0.5" opacity="0.05"/>
        <line x1="100" y1="40" x2="170" y2="70" stroke="#000000" stroke-width="0.5" opacity="0.05"/>
      </svg>
    </div>
    <div class="warm-bar"></div>
    <div class="left">
      <div class="accent-mark"></div>
      <h1 class="headline">{{headline}}</h1>
      {{#if subtext}}
      <p class="subtext">{{subtext}}</p>
      {{/if}}
      <div class="brand-left">
        <svg viewBox="0 0 23 23" xmlns="http://www.w3.org/2000/svg"><path d="M 4.448 1.186 C 9.412 -1.598 16.505 0.685 20.293 6.29 C 24.08 11.895 23.127 18.694 18.165 21.479 C 22.385 19.113 23.194 13.33 19.975 8.567 C 16.755 3.805 10.723 1.862 6.506 4.229 C 2.286 6.598 1.477 12.377 4.694 17.142 C 7.914 21.905 13.942 23.848 18.162 21.479 C 13.197 24.266 6.104 21.98 2.317 16.375 C -1.468 10.773 -0.515 3.971 4.447 1.186 Z" fill="{{ds.textDisabled}}" opacity="0.5"/></svg>
        <span class="brand-name">Flywheel</span>
      </div>
    </div>
    <div class="right">
      {{#each data_points}}
      <div class="list-item">
        <div class="item-num">{{addOne @index}}</div>
        <div class="item-text">{{this}}</div>
      </div>
      {{/each}}
    </div>
    <span class="url">flywheelos.com</span>
    <div class="warm-border"></div>
  </div>
</body>
</html>
