<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 1200px;
      height: 630px;
      font-family: {{{ds.fontFamily}}};
      background: {{ds.surface}};
      color: {{ds.textPrimary}};
      overflow: hidden;
    }

    .canvas {
      width: 1200px;
      height: 630px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    .dot-field {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none;
    }

    .brand {
      position: absolute;
      top: 32px;
      left: 56px;
      display: flex;
      align-items: center;
      gap: 8px;
      z-index: 1;
    }

    .brand svg { width: 16px; height: 16px; }

    .brand-name {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: {{ds.textDisabled}};
      text-transform: uppercase;
    }

    .quote-block {
      max-width: 880px;
      text-align: center;
      padding: 0 80px;
      position: relative;
      z-index: 1;
    }

    .quote-accent {
      width: 48px;
      height: 2px;
      background: {{ds.accent}};
      margin: 0 auto 32px;
    }

    .quote-text {
      font-size: 40px;
      font-weight: 600;
      line-height: 1.18;
      letter-spacing: -0.025em;
      color: {{ds.textPrimary}};
    }

    .subtext {
      font-size: 16px;
      font-weight: 400;
      color: {{ds.textMuted}};
      margin-top: 28px;
      max-width: 560px;
      margin-left: auto;
      margin-right: auto;
      line-height: 1.55;
    }

    .url {
      position: absolute;
      bottom: 32px;
      right: 56px;
      font-family: {{{ds.monoFamily}}};
      font-size: 11px;
      color: {{ds.textFaint}};
      z-index: 1;
    }

    .glow {
      position: absolute;
      width: 500px;
      height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(215, 200, 175, 0.08) 0%, transparent 70%);
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      pointer-events: none;
    }
  </style>
</head>
<body>
  <div class="canvas">
    <div class="dot-field">
      {{{ds.decorativePatternSvg}}}
    </div>
    <div class="glow"></div>
    <div class="brand">
      {{#if ds.logoSvg}}{{{ds.logoSvg}}}{{/if}}
      <span class="brand-name">{{ds.brandName}}</span>
    </div>
    <div class="quote-block">
      <div class="quote-accent"></div>
      <h1 class="quote-text">{{headline}}</h1>
      {{#if subtext}}
      <p class="subtext">{{subtext}}</p>
      {{/if}}
    </div>
    <span class="url">{{ds.brandUrl}}</span>
  </div>
</body>
</html>
