<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 1200px;
      height: 630px;
      font-family: {{{ds.fontFamily}}};
      background: {{ds.surface}};
      color: {{ds.textPrimary}};
      overflow: hidden;
    }

    .canvas {
      width: 1200px;
      height: 630px;
      display: grid;
      grid-template-rows: 3px auto 1fr auto;
      position: relative;
    }

    .dot-field {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none;
      z-index: 0;
    }

    .warm-bar {
      background: linear-gradient(90deg, {{ds.accent}} 0%, transparent 35%);
      z-index: 1;
    }

    .header {
      padding: 40px 64px 0;
      z-index: 1;
    }

    .eyebrow {
      font-family: {{{ds.monoFamily}}};
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: {{ds.textMuted}};
      margin-bottom: 12px;
    }

    .headline {
      font-size: 34px;
      font-weight: 600;
      line-height: 1.1;
      letter-spacing: -0.03em;
      color: {{ds.textPrimary}};
      max-width: 800px;
    }

    .subtext {
      font-size: 15px;
      font-weight: 400;
      color: {{ds.textSubtle}};
      margin-top: 8px;
      max-width: 600px;
      line-height: 1.5;
    }

    .stats-row {
      display: flex;
      gap: 1px;
      padding: 0 64px;
      align-items: stretch;
      z-index: 1;
    }

    .stat-tile {
      flex: 1;
      background: {{ds.background}};
      border: 1px solid rgba(215, 200, 175, 0.5);
      box-shadow: rgba(215, 200, 175, 0.25) 0px 4px 20px 0px, rgba(0, 0, 0, 0.06) 0px 1px 4px 0px, rgba(255, 252, 248, 0.5) 0px 1px 1px 0px inset, rgba(215, 200, 175, 0.15) 0px -1px 1px 0px inset;
      padding: 28px 24px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 8px;
    }

    .stat-value {
      font-family: {{{ds.monoFamily}}};
      font-size: 36px;
      font-weight: 500;
      color: {{ds.primary}};
      line-height: 1;
      letter-spacing: -0.02em;
    }

    .stat-label {
      font-size: 13px;
      font-weight: 500;
      color: {{ds.textMuted}};
      text-transform: uppercase;
      letter-spacing: 0.04em;
      line-height: 1.3;
    }

    .stat-text-only {
      font-family: {{{ds.monoFamily}}};
      font-size: 16px;
      font-weight: 400;
      color: {{ds.textSubtle}};
      line-height: 1.5;
    }

    .footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 64px 28px;
      z-index: 1;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .brand svg { width: 16px; height: 16px; }

    .brand-name {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: {{ds.textDisabled}};
      text-transform: uppercase;
    }

    .url {
      font-family: {{{ds.monoFamily}}};
      font-size: 11px;
      color: {{ds.textFaint}};
    }
  </style>
</head>
<body>
  <div class="canvas">
    <div class="dot-field">
