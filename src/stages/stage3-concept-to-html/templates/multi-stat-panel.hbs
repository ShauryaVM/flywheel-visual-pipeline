        <line x1="1080" y1="210" x2="1160" y2="250" stroke="#000000" stroke-width="0.5" opacity="0.05"/>
        <line x1="1140" y1="310" x2="1100" y2="360" stroke="#000000" stroke-width="0.5" opacity="0.05"/>
        <line x1="1160" y1="400" x2="1080" y2="430" stroke="#000000" stroke-width="0.5" opacity="0.04"/>
        <line x1="1100" y1="510" x2="1160" y2="540" stroke="#000000" stroke-width="0.5" opacity="0.05"/>
        <line x1="1050" y1="560" x2="950" y2="580" stroke="#000000" stroke-width="0.5" opacity="0.05"/>
      </svg>
    </div>
    <div class="warm-bar"></div>
    <div class="header">
      <div class="eyebrow">By the Numbers</div>
      <h1 class="headline">{{headline}}</h1>
      {{#if subtext}}
      <p class="subtext">{{subtext}}</p>
      {{/if}}
    </div>
    <div class="stats-row">
      {{#each data_points}}
      <div class="stat-tile">
        {{#if (contains this "|")}}
        <div class="stat-value">{{statValue this}}</div>
        <div class="stat-label">{{statLabel this}}</div>
        {{else}}
        <div class="stat-text-only">{{this}}</div>
        {{/if}}
      </div>
      {{/each}}
    </div>
    <div class="footer">
      <div class="brand">
        <svg viewBox="0 0 23 23" xmlns="http://www.w3.org/2000/svg"><path d="M 4.448 1.186 C 9.412 -1.598 16.505 0.685 20.293 6.29 C 24.08 11.895 23.127 18.694 18.165 21.479 C 22.385 19.113 23.194 13.33 19.975 8.567 C 16.755 3.805 10.723 1.862 6.506 4.229 C 2.286 6.598 1.477 12.377 4.694 17.142 C 7.914 21.905 13.942 23.848 18.162 21.479 C 13.197 24.266 6.104 21.98 2.317 16.375 C -1.468 10.773 -0.515 3.971 4.447 1.186 Z" fill="{{ds.textDisabled}}" opacity="0.5"/></svg>
        <span class="brand-name">Flywheel</span>
      </div>
      <span class="url">flywheelos.com</span>
    </div>
  </div>
</body>
</html>
