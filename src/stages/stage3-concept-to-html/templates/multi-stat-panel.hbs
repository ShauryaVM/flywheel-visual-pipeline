        <circle cx="800" cy="120" r="6" fill="#000000" opacity="0.08"/>
        <circle cx="880" cy="95" r="3" fill="#000000" opacity="0.16"/>
        <circle cx="960" cy="115" r="10" fill="#000000" opacity="0.07"/>
        <circle cx="1050" cy="100" r="4" fill="#000000" opacity="0.14"/>
