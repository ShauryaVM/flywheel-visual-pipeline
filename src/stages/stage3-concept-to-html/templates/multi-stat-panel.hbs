        <circle cx="1160" cy="250" r="3" fill="#000000" opacity="0.16"/>
        <circle cx="50" cy="300" r="5" fill="#000000" opacity="0.08"/>
        <circle cx="1140" cy="310" r="6" fill="#000000" opacity="0.09"/>
        <circle cx="1100" cy="360" r="4" fill="#000000" opacity="0.12"/>
        <circle cx="70" cy="400" r="3" fill="#000000" opacity="0.14"/>
