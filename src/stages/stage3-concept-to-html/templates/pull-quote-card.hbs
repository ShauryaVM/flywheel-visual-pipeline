<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 1200px;
      height: 630px;
      font-family: {{{ds.fontFamily}}};
      background: {{{ds.backgroundStyle}}};
      color: {{ds.textPrimary}};
      overflow: hidden;
    }

    .canvas {
      width: 1200px;
      height: 630px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    .warm-bar {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 3px;
      background: linear-gradient(90deg, {{ds.accent}} 0%, transparent 50%);
    }

    .quote-container {
      background: {{ds.background}};
      border: 1px solid rgba({{ds.accentRgb}}, 0.5);
      box-shadow: rgba({{ds.accentRgb}}, 0.25) 0px 4px 20px 0px, rgba(0, 0, 0, 0.06) 0px 1px 4px 0px, rgba(255, 255, 255, 0.5) 0px 1px 1px 0px inset, rgba({{ds.accentRgb}}, 0.15) 0px -1px 1px 0px inset;
      padding: 56px 72px;
      max-width: 920px;
      width: 100%;
      position: relative;
    }

    .accent-corner {
      position: absolute;
      top: 0;
      left: 0;
      width: 3px;
      height: 60px;
      background: {{ds.accent}};
    }

    .quote-mark {
      font-size: 72px;
      line-height: 0.5;
      color: {{ds.accent}};
      font-family: Georgia, 'Times New Roman', serif;
      margin-bottom: 24px;
    }

    .quote-text {
      font-size: 34px;
      font-weight: 600;
      line-height: 1.25;
      letter-spacing: -0.025em;
      color: {{ds.textPrimary}};
      margin-bottom: 20px;
    }

    .subtext {
      font-size: 16px;
      font-weight: 400;
      line-height: 1.55;
      color: {{ds.textMuted}};
    }

    .footer {
      position: absolute;
      bottom: 28px;
      left: 0;
      right: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 56px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .brand svg { width: 16px; height: 16px; }

    .brand-name {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: {{ds.textDisabled}};
      text-transform: uppercase;
    }

    .url {
      font-family: {{{ds.monoFamily}}};
      font-size: 11px;
      color: {{ds.textFaint}};
    }

    .decorative-bg {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none;
      z-index: 0;
      opacity: 1.0;
    }

    {{{ds.animationsCss}}}
  </style>
</head>
<body>
  <div class="canvas">
    <div class="decorative-bg">
      {{{ds.decorativePatternSvg}}}
    </div>
    {{{ds.animationHintsSvg}}}
    <div class="warm-bar"></div>
    <div class="quote-container">
      <div class="accent-corner"></div>
      <div class="quote-mark">&ldquo;</div>
      <h1 class="quote-text">{{headline}}</h1>
      {{#if subtext}}
      <p class="subtext">{{subtext}}</p>
      {{/if}}
    </div>
    <div class="footer">
      <div class="brand">
        {{#if ds.logoSvg}}{{{ds.logoSvg}}}{{/if}}
        <span class="brand-name">{{ds.brandName}}</span>
      </div>
      <span class="url">{{ds.brandUrl}}</span>
    </div>
  </div>
</body>
</html>
