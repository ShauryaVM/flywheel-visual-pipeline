<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 1200px;
      height: 630px;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #1a1a1a;
      color: #ffffff;
      overflow: hidden;
    }

    .container {
      width: 1200px;
      height: 630px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 56px 100px;
      position: relative;
    }

    .quote-mark {
      font-size: 100px;
      line-height: 0.6;
      color: #e6ff00;
      font-family: Georgia, 'Times New Roman', serif;
      margin-bottom: 16px;
      opacity: 0.8;
    }

    .quote-text {
      font-size: 44px;
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: -0.025em;
      text-align: center;
      max-width: 880px;
    }

    {{#if subtext}}
    .subtext {
      font-size: 17px;
      font-weight: 400;
      color: rgba(255, 255, 255, 0.45);
      margin-top: 28px;
      text-align: center;
      max-width: 600px;
    }
    {{/if}}

    .logo {
      position: absolute;
      bottom: 32px;
      right: 48px;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: rgba(255, 255, 255, 0.2);
      text-transform: uppercase;
    }

    .bottom-line {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 3px;
      background: linear-gradient(90deg, transparent 10%, #e6ff00 50%, transparent 90%);
      opacity: 0.5;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="quote-mark">"</div>
    <h1 class="quote-text">{{headline}}</h1>
    {{#if subtext}}
    <p class="subtext">{{subtext}}</p>
    {{/if}}
    <div class="logo">Flywheel</div>
    <div class="bottom-line"></div>
  </div>
</body>
</html>
