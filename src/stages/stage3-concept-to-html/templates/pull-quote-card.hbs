    </div>
    <div class="warm-bar"></div>
    <div class="quote-container">
      <div class="accent-corner"></div>
      <div class="quote-mark">&ldquo;</div>
      <h1 class="quote-text">{{headline}}</h1>
      {{#if subtext}}
      <p class="subtext">{{subtext}}</p>
