<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 1200px;
      height: 630px;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #111111;
      color: #ffffff;
      overflow: hidden;
    }

    .container {
      width: 1200px;
      height: 630px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 64px 100px;
      position: relative;
    }

    .statement {
      font-size: 52px;
      font-weight: 700;
      line-height: 1.15;
      letter-spacing: -0.03em;
      max-width: 880px;
      position: relative;
      z-index: 1;
    }

    .highlight {
      color: #e6ff00;
    }

    .decorative-bar {
      position: absolute;
      bottom: 56px;
      left: 50%;
      transform: translateX(-50%);
      width: 64px;
      height: 3px;
      background: #e6ff00;
      border-radius: 2px;
    }

    .logo {
      position: absolute;
      top: 36px;
      right: 48px;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: rgba(255, 255, 255, 0.3);
      text-transform: uppercase;
    }

    .glow {
      position: absolute;
      width: 400px;
      height: 400px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(230, 255, 0, 0.06) 0%, transparent 70%);
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      pointer-events: none;
    }

    {{#if subtext}}
    .subtext {
      font-size: 18px;
      font-weight: 400;
      color: rgba(255, 255, 255, 0.5);
      margin-top: 24px;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }
    {{/if}}
  </style>
</head>
<body>
  <div class="container">
    <div class="glow"></div>
    <div class="logo">Flywheel</div>
    <div>
      <h1 class="statement">{{headline}}</h1>
      {{#if subtext}}
      <p class="subtext">{{subtext}}</p>
      {{/if}}
    </div>
    <div class="decorative-bar"></div>
  </div>
</body>
</html>
