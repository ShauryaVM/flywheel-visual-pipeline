<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 1200px;
      height: 630px;
      font-family: {{{ds.fontFamily}}};
      background: {{ds.surface}};
      color: {{ds.textPrimary}};
      overflow: hidden;
    }

    .canvas {
      width: 1200px;
      height: 630px;
      position: relative;
      display: flex;
      flex-direction: column;
    }

    .warm-bar {
      height: 3px;
      background: linear-gradient(90deg, {{ds.accent}} 0%, transparent 40%);
      flex-shrink: 0;
    }

    .dot-field {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none;
    }

    .brand {
      position: absolute;
      top: 32px;
      right: 56px;
      display: flex;
      align-items: center;
      gap: 8px;
      z-index: 1;
    }

    .brand svg { width: 18px; height: 18px; }

    .brand-name {
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: {{ds.textDisabled}};
      text-transform: uppercase;
    }

    .content {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 60px 100px;
      position: relative;
      z-index: 1;
    }

    .statement {
      font-size: 48px;
      font-weight: 600;
      line-height: 1.1;
      letter-spacing: -0.03em;
      max-width: 900px;
    }

    .accent-underline {
      width: 56px;
      height: 2px;
      background: {{ds.accent}};
      margin: 32px auto 0;
    }

    .subtext {
      font-size: 18px;
      font-weight: 400;
      color: {{ds.textMuted}};
      margin-top: 24px;
      max-width: 580px;
      line-height: 1.55;
    }

    .footer {
      display: flex;
      align-items: center;
      justify-content: center;
      padding-bottom: 36px;
      position: relative;
      z-index: 1;
    }

    .url {
      font-family: {{{ds.monoFamily}}};
      font-size: 12px;
      color: {{ds.textFaint}};
    }

    .glow {
      position: absolute;
      width: 600px;
      height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(215, 200, 175, 0.08) 0%, transparent 70%);
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      pointer-events: none;
    }

    .brand-watermark {
      position: absolute;
      bottom: 60px;
      left: 0;
      width: 100%;
      text-align: center;
      font-size: 140px;
      font-weight: 700;
      letter-spacing: 0.05em;
      color: rgba(0, 0, 0, 0.03);
      text-transform: uppercase;
      pointer-events: none;
      line-height: 1;
    }
  </style>
</head>
<body>
  <div class="canvas">
    <div class="warm-bar"></div>
    <div class="dot-field">
      {{{ds.decorativePatternSvg}}}
    </div>
    <div class="glow"></div>
    <div class="brand-watermark">{{ds.logoText}}</div>
    <div class="brand">
      {{#if ds.logoSvg}}{{{ds.logoSvg}}}{{/if}}
      <span class="brand-name">{{ds.brandName}}</span>
    </div>
    <div class="content">
      <h1 class="statement">{{headline}}</h1>
      <div class="accent-underline"></div>
      {{#if subtext}}
      <p class="subtext">{{subtext}}</p>
      {{/if}}
    </div>
    <div class="footer">
      <span class="url">{{ds.brandUrl}}</span>
    </div>
  </div>
</body>
</html>
