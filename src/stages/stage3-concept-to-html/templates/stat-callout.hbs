<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 1200px;
      height: 630px;
      font-family: {{{ds.fontFamily}}};
      background: {{{ds.backgroundStyle}}};
      color: {{ds.textPrimary}};
      overflow: hidden;
    }

    .canvas {
      width: 1200px;
      height: 630px;
      display: flex;
      position: relative;
    }

    .warm-bar {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 3px;
      background: linear-gradient(90deg, {{ds.accent}} 0%, transparent 50%);
    }

    .stat-side {
      flex: 0 0 480px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      {{{ds.cardStyle}}};
      border-right: 1px solid rgba({{ds.accentRgb}}, 0.5);
      padding: 48px;
      position: relative;
      overflow: hidden;
    }


    .stat-value {
      font-family: {{{ds.monoFamily}}};
      font-size: 100px;
      font-weight: 500;
      line-height: 1;
      color: {{ds.primary}};
      letter-spacing: -0.03em;
      position: relative;
      z-index: 1;
    }

    .stat-unit {
      font-family: {{{ds.monoFamily}}};
      font-size: 14px;
      font-weight: 400;
      color: {{ds.textMuted}};
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-top: 12px;
      position: relative;
      z-index: 1;
    }

    .text-side {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 56px 64px;
    }

    .eyebrow {
      font-family: {{{ds.monoFamily}}};
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: {{ds.textFaint}};
      margin-bottom: 16px;
    }

    .headline {
      font-size: 32px;
      font-weight: 600;
      line-height: 1.15;
      letter-spacing: -0.025em;
      color: {{ds.primary}};
      margin-bottom: 20px;
    }

    .divider {
      width: 40px;
      height: 2px;
      background: {{ds.accent}};
      margin-bottom: 20px;
    }

    .subtext {
      font-size: 17px;
      font-weight: 400;
      line-height: 1.6;
      color: {{ds.textSubtle}};
      max-width: 480px;
    }

    .footer {
      position: absolute;
      bottom: 28px;
      right: 48px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .footer svg { width: 16px; height: 16px; }

    .brand-name {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: {{ds.textDisabled}};
      text-transform: uppercase;
    }

    .decorative-bg {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none;
      z-index: 0;
      opacity: 1.0;
    }

    .warm-border {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 1px;
      background: rgba({{ds.accentRgb}}, 0.4);
    }

    {{{ds.animationsCss}}}
  </style>
</head>
<body>
  <div class="canvas">
    <div class="decorative-bg">
      {{{ds.decorativePatternSvg}}}
    </div>
    {{{ds.animationHintsSvg}}}
    <div class="warm-bar"></div>
    <div class="stat-side">
      {{#if data_points.[0]}}
      <div class="stat-value">{{statValue data_points.[0]}}</div>
      <div class="stat-unit">{{statLabel data_points.[0]}}</div>
      {{/if}}
    </div>
    <div class="text-side">
      <div class="eyebrow">Data Point</div>
      <h1 class="headline">{{headline}}</h1>
      <div class="divider"></div>
      {{#if subtext}}
      <p class="subtext">{{subtext}}</p>
      {{/if}}
    </div>
    <div class="footer">
      {{#if ds.logoSvg}}{{{ds.logoSvg}}}{{/if}}
      <span class="brand-name">{{ds.brandName}}</span>
    </div>
    <span class="url" style="position:absolute;bottom:28px;left:48px;font-family:{{{ds.monoFamily}}};font-size:11px;color:{{ds.textFaint}};">{{ds.brandUrl}}</span>
    <div class="warm-border"></div>
  </div>
</body>
</html>
