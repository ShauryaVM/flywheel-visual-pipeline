<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 1200px;
      height: 630px;
      font-family: {{{ds.fontFamily}}};
      background: {{ds.background}};
      color: {{ds.textPrimary}};
      overflow: hidden;
    }

    .canvas {
      width: 1200px;
      height: 630px;
      display: flex;
      position: relative;
    }

    .warm-bar {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 3px;
      background: linear-gradient(90deg, {{ds.accent}} 0%, transparent 50%);
    }

    .stat-side {
      flex: 0 0 480px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: {{ds.surface}};
      border-right: 1px solid rgba(215, 200, 175, 0.5);
      box-shadow: rgba(215, 200, 175, 0.25) 0px 4px 20px 0px, rgba(0, 0, 0, 0.06) 0px 1px 4px 0px, rgba(255, 252, 248, 0.5) 0px 1px 1px 0px inset, rgba(215, 200, 175, 0.15) 0px -1px 1px 0px inset;
      padding: 48px;
      position: relative;
      overflow: hidden;
    }

    .stat-dots {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none;
    }

    .stat-value {
      font-family: {{{ds.monoFamily}}};
      font-size: 100px;
      font-weight: 500;
      line-height: 1;
      color: {{ds.primary}};
      letter-spacing: -0.03em;
      position: relative;
      z-index: 1;
    }

    .stat-unit {
      font-family: {{{ds.monoFamily}}};
      font-size: 14px;
      font-weight: 400;
      color: {{ds.textMuted}};
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-top: 12px;
      position: relative;
      z-index: 1;
    }

    .text-side {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 56px 64px;
    }

    .eyebrow {
      font-family: {{{ds.monoFamily}}};
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: {{ds.textFaint}};
      margin-bottom: 16px;
    }

    .headline {
      font-size: 32px;
      font-weight: 600;
      line-height: 1.15;
      letter-spacing: -0.025em;
      color: {{ds.primary}};
      margin-bottom: 20px;
    }

    .divider {
      width: 40px;
      height: 2px;
      background: {{ds.accent}};
      margin-bottom: 20px;
    }

    .subtext {
      font-size: 17px;
      font-weight: 400;
      line-height: 1.6;
      color: {{ds.textSubtle}};
      max-width: 480px;
    }

    .footer {
      position: absolute;
      bottom: 28px;
      right: 48px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .footer svg { width: 16px; height: 16px; }

    .brand-name {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: {{ds.textDisabled}};
      text-transform: uppercase;
    }

    .dot-field {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none;
      z-index: 0;
    }

    .warm-border {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 1px;
      background: rgba(215, 200, 175, 0.4);
    }
  </style>
</head>
<body>
  <div class="canvas">
    <div class="dot-field">
      {{{ds.decorativePatternSvg}}}
    </div>
    <div class="warm-bar"></div>
    <div class="stat-side">
      <svg class="stat-dots" width="480" height="630" xmlns="http://www.w3.org/2000/svg">
        <circle cx="60" cy="60" r="4" fill="#000000" opacity="0.12"/>
        <circle cx="130" cy="100" r="6" fill="#000000" opacity="0.08"/>
        <circle cx="400" cy="70" r="3" fill="#000000" opacity="0.15"/>
        <circle cx="350" cy="140" r="5" fill="#000000" opacity="0.1"/>
        <circle cx="80" cy="180" r="8" fill="#000000" opacity="0.07"/>
        <circle cx="420" cy="200" r="3" fill="#000000" opacity="0.16"/>
        <circle cx="200" cy="50" r="2" fill="#000000" opacity="0.18"/>
        <circle cx="300" cy="80" r="4" fill="#000000" opacity="0.1"/>
        <circle cx="440" cy="350" r="5" fill="#000000" opacity="0.08"/>
        <circle cx="50" cy="400" r="6" fill="#000000" opacity="0.07"/>
        <circle cx="380" cy="450" r="3" fill="#000000" opacity="0.14"/>
        <circle cx="120" cy="500" r="7" fill="#000000" opacity="0.06"/>
        <circle cx="350" cy="520" r="4" fill="#000000" opacity="0.12"/>
        <circle cx="80" cy="560" r="5" fill="#000000" opacity="0.08"/>
        <circle cx="420" cy="570" r="3" fill="#000000" opacity="0.14"/>
        <circle cx="250" cy="580" r="4" fill="#000000" opacity="0.1"/>
        <line x1="60" y1="60" x2="130" y2="100" stroke="#000000" stroke-width="0.5" opacity="0.05"/>
        <line x1="400" y1="70" x2="350" y2="140" stroke="#000000" stroke-width="0.5" opacity="0.04"/>
        <line x1="80" y1="560" x2="120" y2="500" stroke="#000000" stroke-width="0.5" opacity="0.05"/>
      </svg>
      {{#if data_points.[0]}}
      <div class="stat-value">{{statValue data_points.[0]}}</div>
      <div class="stat-unit">{{statLabel data_points.[0]}}</div>
      {{/if}}
    </div>
    <div class="text-side">
      <div class="eyebrow">Data Point</div>
      <h1 class="headline">{{headline}}</h1>
      <div class="divider"></div>
      {{#if subtext}}
      <p class="subtext">{{subtext}}</p>
      {{/if}}
    </div>
    <div class="footer">
      {{#if ds.logoSvg}}{{{ds.logoSvg}}}{{/if}}
      <span class="brand-name">{{ds.brandName}}</span>
    </div>
    <span class="url" style="position:absolute;bottom:28px;left:48px;font-family:{{{ds.monoFamily}}};font-size:11px;color:{{ds.textFaint}};">{{ds.brandUrl}}</span>
    <div class="warm-border"></div>
  </div>
</body>
</html>
